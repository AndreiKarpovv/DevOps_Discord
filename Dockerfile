# Используем легкий образ Node.js
FROM node:20-slim

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем остальной код
COPY . .

# Команда для запуска (теперь процесс будет вечным из-за while в коде)
CMD ["node", "index.js"]